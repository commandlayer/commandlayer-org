{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.commandlayer.org/schemas/v1.0.0/trust/sign/sign.receipt.schema.json",
  "title": "CLAS Trust Sign Receipt",
  "description": "A signed receipt proving that a signing action was performed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "family",
    "verb",
    "receipt_id",
    "request",
    "signature_result",
    "ts",
    "metadata"
  ],
  "properties": {
    "version": {
      "const": "1.0.0"
    },
    "family": {
      "const": "trust"
    },
    "verb": {
      "const": "sign"
    },
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "request": {
      "$ref": "./sign.request.schema.json"
    },
    "signature_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "signature_alg",
        "signature",
        "key_id"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "signed",
            "refused",
            "failed"
          ]
        },
        "signature_alg": {
          "const": "ed25519"
        },
        "signature": {
          "type": "string",
          "minLength": 16
        },
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "content_hash": {
          "type": "string",
          "pattern": "^sha256:[a-fA-F0-9]{64}$"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof"
      ],
      "properties": {
        "proof": {
          "$ref": "../_shared/proof.schema.json"
        },
        "trace": {
          "$ref": "../_shared/trace.schema.json"
        }
      }
    },
    "chain_root": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional receipt chain root. Genesis receipts set this to the claim receipt_chain_root; action/example receipts may use null until full receipt storage is available.",
      "minLength": 1
    },
    "previous_receipt_hash": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional hash of the previous receipt in the chain. May be null until full receipt storage is available.",
      "minLength": 1
    },
    "chain_index": {
      "type": [
        "integer",
        "null"
      ],
      "description": "Optional zero-based index in the receipt chain. Genesis receipts use 0; action/example receipts may use null until full receipt storage is available.",
      "minimum": 0
    },
    "parent_receipt_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional parent receipt identifier supplied by the caller when a receipt is linked to an earlier receipt. May be null until full receipt storage is available.",
      "minLength": 1
    }
  }
}
