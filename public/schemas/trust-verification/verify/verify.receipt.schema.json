{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.commandlayer.org/schemas/v1.0.0/trust/verify/verify.receipt.schema.json",
  "title": "CLAS Trust Verify Receipt",
  "description": "A signed receipt proving that a verification action was performed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "family",
    "verb",
    "receipt_id",
    "request",
    "result",
    "ts",
    "metadata"
  ],
  "properties": {
    "version": {
      "const": "1.0.0"
    },
    "family": {
      "const": "trust"
    },
    "verb": {
      "const": "verify"
    },
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "request": {
      "$ref": "./verify.request.schema.json"
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "verified",
            "unverified",
            "invalid",
            "inconclusive"
          ]
        },
        "reason": {
          "type": "string"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "passed"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "passed": {
                "type": "boolean"
              },
              "detail": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof"
      ],
      "properties": {
        "proof": {
          "$ref": "../_shared/proof.schema.json"
        },
        "trace": {
          "$ref": "../_shared/trace.schema.json"
        }
      }
    },
    "chain_root": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional receipt chain root. Genesis receipts set this to sha256:<genesis_anchor_hash>, where the anchor hash excludes the derived chain_root field to avoid circular hashing; action/example receipts may use null until full receipt storage is available.",
      "minLength": 1
    },
    "previous_receipt_hash": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional hash of the previous receipt in the chain. May be null until full receipt storage is available.",
      "minLength": 1
    },
    "chain_index": {
      "type": [
        "integer",
        "null"
      ],
      "description": "Optional zero-based index in the receipt chain. Genesis receipts use 0; action/example receipts may use null until full receipt storage is available.",
      "minimum": 0
    },
    "parent_receipt_id": {
      "type": [
        "string",
        "null"
      ],
      "description": "Optional parent receipt identifier supplied by the caller when a receipt is linked to an earlier receipt. May be null until full receipt storage is available.",
      "minLength": 1
    }
  }
}
